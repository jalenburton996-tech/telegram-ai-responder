NODE_ENV=development
PORT=3000
LOG_LEVEL=info
DATABASE_URL=postgres://postgres:postgres@localhost:5432/telegram_ai
REDIS_URL=redis://localhost:6379

# Generate independently, e.g. `openssl rand -hex 32`. Never reuse either value.
TELEGRAM_BOT_TOKEN=replace_me
TELEGRAM_WEBHOOK_SECRET=replace_with_32_or_more_random_characters
PUBLIC_BASE_URL=https://your-service.example.com
AUTO_CONFIGURE_WEBHOOK=false
EMBEDDED_WORKER=false

OPENAI_API_KEY=replace_me
OPENAI_MODEL=gpt-5.4-mini
OPENAI_MAX_OUTPUT_TOKENS=500

BUSINESS_NAME=Your Business
BUSINESS_CONTEXT=Describe services, prices, policies, links, and facts the assistant may state.
ASSISTANT_TONE=Friendly, concise, accurate, and transparent that you are an AI assistant.
ESCALATION_MESSAGE=I’m handing this to a person who can help. They’ll reply as soon as possible.

TIMEZONE=America/New_York
# Seven comma-separated day rules; use `closed` or HH:mm-HH:mm. Monday is first.
BUSINESS_HOURS=09:00-17:00,09:00-17:00,09:00-17:00,09:00-17:00,09:00-17:00,closed,closed
OUT_OF_HOURS_MODE=hold
OUT_OF_HOURS_MESSAGE=Thanks for your message. We’re currently closed and will reply during business hours.

# Telegram numeric user IDs (not @usernames). Empty allowlist means all, subject to denylist.
ALLOW_USER_IDS=
DENY_USER_IDS=
MAX_REPLIES_PER_CHAT_PER_HOUR=12
MAX_GLOBAL_REPLIES_PER_MINUTE=30
MANUAL_TAKEOVER_MINUTES=120
MEMORY_MESSAGES=12
MEMORY_RETENTION_DAYS=30
REPLY_DELAY_MS=1500
